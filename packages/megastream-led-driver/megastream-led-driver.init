#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

SCRIPT=/usr/local/bin/megastream-led-driver.sh

start_service() {
    procd_open_instance
    procd_set_param command "$SCRIPT" -d 1
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
