#!/bin/sh
# ZTP config update daemon
# Fetches config from server, applies only changed packages, restarts affected services
# Runs continuously with exponential backoff on failure

RETRY_MIN=10
RETRY_MAX=3600

retry_delay=$RETRY_MIN

# ---------------------------------------------------------------------------
# Functions
# ---------------------------------------------------------------------------

extract_package() {
    local pkg="$1"
    awk "
        /^package ${pkg}\$/ { found=1; print; next }
        /^package /         { if (found) exit }
        found               { print }
    " "$TMP_CONFIG"
}

restart_for_package() {
    local pkg="$1"
    case "$pkg" in
        network)  /etc/init.d/network restart ;;
        firewall) /etc/init.d/firewall restart ;;
        dhcp)     /etc/init.d/dnsmasq restart ;;
        system)   /etc/init.d/system restart ;;
        wireless) wifi reload ;;
        *)        [ -x "/etc/init.d/$pkg" ] && /etc/init.d/$pkg restart ;;
    esac
}

backoff() {
    logger -s -t ztp "Retrying in ${retry_delay}s"
    sleep "$retry_delay"
    retry_delay=$(( retry_delay * 2 ))
    [ "$retry_delay" -gt "$RETRY_MAX" ] && retry_delay=$RETRY_MAX
}

# ---------------------------------------------------------------------------
# Main daemon loop
# ---------------------------------------------------------------------------

while true; do
    CLIENT_CERT=$(uci get ztp.config.cert 2>/dev/null || echo "/etc/ssl/certs/user.crt")
    CLIENT_KEY=$(uci get ztp.config.key 2>/dev/null || echo "/etc/ssl/private/user.key")
    SERVER=$(uci get ztp.config.server 2>/dev/null || echo "http://192.168.1.1/config")
    POLL_INTERVAL=$(uci get ztp.config.poll_interval 2>/dev/null || echo 3600)
    MAC=$(cat /sys/class/net/$(uci get network.wan.device)/address | tr -d ':' | awk '{print toupper($0)}')
    CONFIG_URL="${SERVER}/config/${MAC}/config.uci"
    ETAG=$(uci get ztp.config.etag 2>/dev/null)
    TMP_CONFIG="/tmp/ztp_pending.uci"
    TMP_HEADERS="/tmp/ztp_headers.txt"

    if [ ! -f "$CLIENT_CERT" ] || [ ! -f "$CLIENT_KEY" ]; then
        logger -s -t ztp "Client cert or key not found (cert: $CLIENT_CERT, key: $CLIENT_KEY)"
        backoff
        continue
    fi

    # ---------------------------------------------------------------------------
    # Fetch config from server
    # ---------------------------------------------------------------------------

    logger -s -t ztp "Fetching config. URL: $CONFIG_URL ETag: ${ETAG:-(none)}"
    HTTP_CODE=$(curl -s \
        --max-time 30 \
        --cert "$CLIENT_CERT" \
        --key "$CLIENT_KEY" \
        -o "$TMP_CONFIG" \
        -D "$TMP_HEADERS" \
        -w "%{http_code}" \
        ${ETAG:+-H "If-None-Match: $ETAG"} \
        "$CONFIG_URL")
    logger -s -t ztp "HTTP response: $HTTP_CODE"

    case "$HTTP_CODE" in
        304)
            logger -s -t ztp "Config up to date, next poll in ${POLL_INTERVAL}s"
            retry_delay=$RETRY_MIN
            sleep "$POLL_INTERVAL"
            continue
            ;;
        200)
            ;;
        *)
            logger -s -t ztp "Unexpected response: $HTTP_CODE"
            backoff
            continue
            ;;
    esac

    # ---------------------------------------------------------------------------
    # Diff per-package to determine which services need restarting
    # ---------------------------------------------------------------------------

    logger -s -t ztp "Checking for changes..."

    CHANGED_PKGS=""
    for pkg in $(grep '^package ' "$TMP_CONFIG" | awk '{print $2}'); do
        [ "$pkg" = "ztp" ] && continue

        current=$(uci export "$pkg" 2>/dev/null)
        incoming=$(extract_package "$pkg")

        if [ "$current" != "$incoming" ]; then
            CHANGED_PKGS="$CHANGED_PKGS $pkg"
            logger -s -t ztp "Changed: $pkg"
            diff <(echo "$current") <(echo "$incoming") >&2
        else
            logger -s -t ztp "Unchanged: $pkg"
        fi
    done

    # ---------------------------------------------------------------------------
    # Apply config
    # ---------------------------------------------------------------------------

    logger -s -t ztp "Importing config..."
    uci import < "$TMP_CONFIG"

    NEW_ETAG=$(grep -i '^etag:' "$TMP_HEADERS" | tr -d '\r' | awk '{print $2}')
    if [ -n "$NEW_ETAG" ]; then
        logger -s -t ztp "Saving ETag: $NEW_ETAG"
        uci set ztp.config.etag="$NEW_ETAG"
        uci commit ztp
    fi

    # ---------------------------------------------------------------------------
    # Install any packages listed in ztp config
    # ---------------------------------------------------------------------------

    PKGS=$(uci get ztp.config.packages 2>/dev/null)
    if [ -n "$PKGS" ]; then
        for pkg in $PKGS; do
            if apk info -e "$pkg" 2>/dev/null; then
                logger -s -t ztp "Package already installed: $pkg"
            else
                logger -s -t ztp "Installing package: $pkg"
                apk update 2>/dev/null
                apk add "$pkg"
            fi
        done
    fi

    # ---------------------------------------------------------------------------
    # Restart only affected services
    # ---------------------------------------------------------------------------

    for pkg in $CHANGED_PKGS; do
        logger -s -t ztp "Restarting service for: $pkg"
        restart_for_package "$pkg"
    done

    logger -s -t ztp "Done. Changed packages:${CHANGED_PKGS:- none}"

    # ---------------------------------------------------------------------------
    # Download and apply any file sections
    # ---------------------------------------------------------------------------

    uci show ztp 2>/dev/null | grep -o 'ztp\.@file\[[0-9]*\]' | sort -u | while read section; do
        dest=$(uci get ${section}.dest 2>/dev/null)
        delete=$(uci get ${section}.delete 2>/dev/null)

        [ -z "$dest" ] && continue

        if [ "$delete" = "1" ]; then
            if [ -e "$dest" ]; then
                logger -s -t ztp "Deleting: $dest"
                rm -f "$dest"
            else
                logger -s -t ztp "Already absent: $dest"
            fi
            continue
        fi

        url=$(uci get ${section}.url 2>/dev/null)
        mode=$(uci get ${section}.mode 2>/dev/null || echo '0644')
        run=$(uci get ${section}.run 2>/dev/null)
        file_etag=$(uci get ${section}.etag 2>/dev/null)

        [ -z "$url" ] && continue

        logger -s -t ztp "Checking file: $dest"
        FILE_CODE=$(curl -s --max-time 30 --cert "$CLIENT_CERT" --key "$CLIENT_KEY" \
            -o /tmp/ztp_file.tmp -D /tmp/ztp_file_headers.txt -w "%{http_code}" \
            ${file_etag:+-H "If-None-Match: $file_etag"} \
            "$url")

        case "$FILE_CODE" in
            304)
                logger -s -t ztp "Unchanged: $dest"
                rm -f /tmp/ztp_file.tmp /tmp/ztp_file_headers.txt
                continue
                ;;
            200)
                ;;
            *)
                logger -s -t ztp "Download failed (HTTP $FILE_CODE): $url"
                rm -f /tmp/ztp_file.tmp /tmp/ztp_file_headers.txt
                continue
                ;;
        esac

        if [ ! -s /tmp/ztp_file.tmp ]; then
            logger -s -t ztp "Download empty: $url"
            rm -f /tmp/ztp_file.tmp /tmp/ztp_file_headers.txt
            continue
        fi

        new_file_etag=$(grep -i '^etag:' /tmp/ztp_file_headers.txt | tr -d '\r' | awk '{print $2}')
        rm -f /tmp/ztp_file_headers.txt
        if [ -n "$new_file_etag" ]; then
            uci set ${section}.etag="$new_file_etag"
            uci commit ztp
        fi

        if ! diff -q /tmp/ztp_file.tmp "$dest" > /dev/null 2>&1; then
            logger -s -t ztp "Updating: $dest"
            mv /tmp/ztp_file.tmp "$dest"
            chmod "$mode" "$dest"
            [ "$run" = "1" ] && logger -s -t ztp "Running: $dest" && "$dest"
        else
            logger -s -t ztp "Unchanged: $dest"
            rm /tmp/ztp_file.tmp
        fi
    done

    # ---------------------------------------------------------------------------
    # Self-update (must be last — mv is atomic, new script takes effect next run)
    # ---------------------------------------------------------------------------

    SCRIPT_URL=$(uci get ztp.config.script_url 2>/dev/null)
    if [ -n "$SCRIPT_URL" ]; then
        logger -s -t ztp "Downloading script: $SCRIPT_URL"
        curl -s --cert "$CLIENT_CERT" --key "$CLIENT_KEY" -o /tmp/ztp-script.tmp "$SCRIPT_URL"
        if [ -s /tmp/ztp-script.tmp ]; then
            SCRIPT_DEST=$(uci get ztp.config.script_dest 2>/dev/null)
            if [ -n "$SCRIPT_DEST" ]; then
                mv /tmp/ztp-script.tmp "$SCRIPT_DEST"
                if [ "$(uci get ztp.config.script_run 2>/dev/null)" = "1" ]; then
                    logger -s -t ztp "Running script: $SCRIPT_DEST"
                    chmod +x "$SCRIPT_DEST"
                    "$SCRIPT_DEST"
                fi
            else
                if [ "$(uci get ztp.config.script_run 2>/dev/null)" = "1" ]; then
                    logger -s -t ztp "Running script"
                    chmod +x /tmp/ztp-script.tmp
                    /tmp/ztp-script.tmp
                fi
                rm -f /tmp/ztp-script.tmp
            fi
        else
            logger -s -t ztp "Script download failed or empty"
            rm -f /tmp/ztp-script.tmp
        fi
    fi

    retry_delay=$RETRY_MIN
    logger -s -t ztp "Next poll in ${POLL_INTERVAL}s"
    sleep "$POLL_INTERVAL"
done
